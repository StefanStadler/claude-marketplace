{
  "description": "claude-memory lifecycle hooks",
  "hooks": {
    "Setup": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PLUGIN_ROOT}\" && npm install --silent",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx\" ] || (cd \"${CLAUDE_PLUGIN_ROOT}\" && npm install --silent); \"${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx\" \"${CLAUDE_PLUGIN_ROOT}/src/hooks/session-start.ts\"",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx\" ] || (cd \"${CLAUDE_PLUGIN_ROOT}\" && npm install --silent); \"${CLAUDE_PLUGIN_ROOT}/node_modules/.bin/tsx\" \"${CLAUDE_PLUGIN_ROOT}/src/hooks/stop.ts\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
